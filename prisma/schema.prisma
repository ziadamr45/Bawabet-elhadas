// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USER SYSTEM ============
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  
  // Preferences
  preferredCategories String[] @default(["politics", "technology", "sports"])
  preferredCountry    String   @default("eg")
  notificationEnabled Boolean  @default(true)
  notificationTypes   String[] @default(["breaking", "personalized"])  // breaking, personalized, digest
  
  // OAuth
  accounts     Account[]
  sessions     Session[]
  interactions Interaction[]
  readingHistory ReadingHistory[]
  deviceTokens   DeviceToken[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String  @id @default(cuid())
  sessionToken String  @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============ INTERACTION TRACKING ============
model Interaction {
  id        String   @id @default(cuid())
  userId    String
  articleUrl String
  articleTitle String
  
  // Interaction type
  type      String   // "click", "view", "read", "share", "bookmark"
  
  // Context
  category  String?
  source    String?
  country   String?
  
  // Reading metrics
  readTimeSeconds Int @default(0)
  
  // Timestamp
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([articleUrl])
  @@index([type, createdAt])
}

// ============ READING HISTORY ============
model ReadingHistory {
  id        String   @id @default(cuid())
  userId    String
  articleUrl String
  articleTitle String
  articleImage String?
  articleSource String?
  articleCategory String?
  articleSnippet String?
  articleDate String?
  
  readCount Int      @default(1)
  totalReadTime Int  @default(0)
  bookmarked Boolean @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleUrl])
  @@index([userId, updatedAt])
}

// ============ ARTICLE CACHE ============
model Article {
  id          String   @id @default(cuid())
  url         String   @unique
  title       String
  snippet     String?
  content     String?
  image       String?
  source      String?
  category    String?
  country     String?
  language    String   @default("ar")
  publishedAt DateTime?
  
  // AI generated fields
  aiSummary      String?
  importanceScore Int?
  qualityScore   Int?
  
  // Trending metrics
  viewCount   Int      @default(0)
  clickCount  Int      @default(0)
  shareCount  Int      @default(0)
  trendingScore Float  @default(0)  // Computed trending score (0-100)
  
  // Cache management
  fetchedAt   DateTime @default(now())
  expiresAt   DateTime
  
  @@index([category, publishedAt])
  @@index([country, publishedAt])
  @@index([publishedAt])
  @@index([viewCount])
  @@index([clickCount])
  @@index([trendingScore])
}

// ============ NOTIFICATION SYSTEM ============

// User device subscriptions for Web Push notifications (VAPID)
model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  
  // Web Push subscription fields (from pushManager.subscribe)
  endpoint  String   // Push service endpoint URL
  keys_p256dh String // Client's public key (base64url)
  keys_auth    String // Client's auth secret (base64url)
  
  // Legacy FCM token (kept for backward compat, will be removed)
  token     String?  @unique  // Old FCM device token (deprecated)
  
  platform  String   @default("web")  // web, ios, android
  userAgent String?
  isActive  Boolean  @default(true)
  
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([userId])
  @@index([isActive])
  @@index([endpoint])
}

// Notification log (sent notifications history)
model NotificationLog {
  id          String   @id @default(cuid())
  userId      String?  // null = broadcast
  articleUrl  String?
  articleTitle String?
  articleImage String?
  type        String   // "breaking", "personalized", "digest"
  title       String   // Notification title
  body        String   // Notification body
  data        Json?    // Extra data payload
  
  // Delivery tracking
  status      String   @default("pending")  // pending, sent, delivered, failed
  sentAt      DateTime @default(now())
  deliveredAt DateTime?
  failureReason String?
  
  @@index([userId, sentAt])
  @@index([type, sentAt])
  @@index([status])
}

// Daily digest tracking
model DailyDigest {
  id        String   @id @default(cuid())
  userId    String   @unique
  lastSent  DateTime?
  articleIds String[] @default([])  // IDs of articles included in last digest
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
